# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real keys.
# See SETUP2.md for full setup instructions.

# ── Stripe ────────────────────────────────────────────────────────────────────
# Publishable key (pk_test_... for test mode, pk_live_... for production)
# Get yours at: https://dashboard.stripe.com/test/apikeys
EXPO_PUBLIC_STRIPE_KEY=pk_test_REPLACE_WITH_YOUR_KEY

# ── Mapbox ────────────────────────────────────────────────────────────────────
# Default public token from mapbox.com → Account → Tokens
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiUkVQTEFDRV9XSVRIWVBPVVJfVE9LRU4ifQ.REPLACE_WITH_YOUR_KEY

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Token from @BotFather (format: 123456:ABC-DEF1234ghIkl...)
EXPO_PUBLIC_TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN
# Your personal chat ID (get it from @userinfobot or @RawDataBot)
EXPO_PUBLIC_TELEGRAM_CHAT_ID=REPLACE_WITH_YOUR_CHAT_ID
